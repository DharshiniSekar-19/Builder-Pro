DJANGO_SECRET_KEY=change-this-to-a-very-long-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

DB_ENGINE=django.db.backends.postgresql
DB_NAME=builderpro
DB_USER=builderpro_user
